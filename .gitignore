# ignore all files and all directories
*
*/

!.gitignore
!.github/workflows/ci.yml
!.github/workflows/release.yml
!.github/workflows/
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/**
!.github/
!README.adoc
!docs/
!docs/advanced.adoc
!docs/ble-protocol.adoc
!subzero.yaml
!cove-minimal-dishwasher.yaml
!wolf-minimal-range.yaml
!wolf-minimal-fridge.yaml
!components/
!components/patch_acl_reassembly/
!components/patch_acl_reassembly/**
!components/subzero_protocol/
!components/subzero_protocol/**
!components/subzero_appliance/
!components/subzero_appliance/**
!tests/
!tests/README.md
!tests/fixtures/
!tests/fixtures/**
!tests/cpp/
!tests/cpp/CMakeLists.txt
!tests/cpp/*.cpp
!tests/cpp/*.h

# Re-ignore caches/artifacts that the broad ** allows would otherwise let through.
# Last-matching-rule wins in gitignore, so these override the negations above.
__pycache__/
*.pyc
.DS_Store
